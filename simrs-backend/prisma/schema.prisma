model petugas {
  nip           String    @id @db.VarChar(20)
  nama          String?   @db.VarChar(50)
  jk            petugas_jk?
  tmp_lahir     String?   @db.VarChar(20)
  tgl_lahir     DateTime? @db.Date
  gol_darah     petugas_gol_darah?
  agama         String?   @db.VarChar(12)
  stts_nikah    petugas_stts_nikah?
  alamat        String?   @db.VarChar(60)

  periksa_lab   periksa_lab[]
}

enum petugas_jk {
  Pria
  Wanita
}
enum petugas_gol_darah {
  A
  B
  O
  AB
  STRIP @map("-")
}
enum petugas_stts_nikah {
  BELUM_MENIKAH @map("BELUM MENIKAH")
  MENIKAH
  JANDA
  DUDHA
  STRIP @map("-")
}

model jns_perawatan_lab {
  kd_jenis_prw          String @id @db.VarChar(15)
  nm_perawatan          String? @db.VarChar(80)
  bagian_rs             Float?
  bhp                   Float
  tarif_perujuk         Float
  tarif_tindakan_dokter Float
  tarif_tindakan_petugas Float?
  kso                   Float?
  menejemen             Float?
  total_byr             Float?
  kd_pj                 String @db.Char(3)
  status                String @db.VarChar(1) // '0','1'
  kelas                 String @db.VarChar(15) // '-', 'Kelas 1', etc
  kategori              String @db.VarChar(5) // 'PK', 'PA', 'MB'

  penjab                penjab @relation(fields: [kd_pj], references: [kd_pj])
  periksa_lab           periksa_lab[]
  detail_periksa_lab    detail_periksa_lab[]
}

model template_laboratorium {
  kd_jenis_prw          String @db.VarChar(15)
  id_template           Int @id @default(autoincrement())
  Pemeriksaan           String @db.VarChar(200)
  satuan                String @db.VarChar(20)
  nilai_rujukan_ld      String @db.VarChar(30)
  nilai_rujukan_la      String @db.VarChar(30)
  nilai_rujukan_pd      String @db.VarChar(30)
  nilai_rujukan_pa      String @db.VarChar(30)
  bagian_rs             Float
  bhp                   Float
  bagian_perujuk        Float
  bagian_dokter         Float
  bagian_laborat        Float
  kso                   Float?
  menejemen             Float?
  biaya_item            Float
  urut                  Int?

  detail_periksa_lab    detail_periksa_lab[]
}

model periksa_lab {
  no_rawat              String @db.VarChar(17)
  nip                   String @db.VarChar(20)
  kd_jenis_prw          String @db.VarChar(15)
  tgl_periksa           DateTime @db.Date
  jam                   DateTime @db.Time(0)
  dokter_perujuk        String @db.VarChar(20)
  bagian_rs             Float
  bhp                   Float
  tarif_perujuk         Float
  tarif_tindakan_dokter Float
  tarif_tindakan_petugas Float
  kso                   Float?
  menejemen             Float?
  biaya                 Float
  kd_dokter             String @db.VarChar(20)
  status                String? @db.VarChar(15)
  kategori              String @db.VarChar(5) // 'PK', 'PA', 'MB'

  reg_periksa           reg_periksa @relation(fields: [no_rawat], references: [no_rawat])
  petugas               petugas @relation(fields: [nip], references: [nip])
  jns_perawatan_lab     jns_perawatan_lab @relation(fields: [kd_jenis_prw], references: [kd_jenis_prw])
  dokter_perujuk_rel    dokter @relation("periksa_lab_dokter_perujuk", fields: [dokter_perujuk], references: [kd_dokter])
  dokter_periksa_rel    dokter @relation("periksa_lab_dokter", fields: [kd_dokter], references: [kd_dokter])

  @@id([no_rawat, kd_jenis_prw, tgl_periksa, jam])
}

model detail_periksa_lab {
  no_rawat              String @db.VarChar(17)
  kd_jenis_prw          String @db.VarChar(15)
  tgl_periksa           DateTime @db.Date
  jam                   DateTime @db.Time(0)
  id_template           Int
  nilai                 String @db.VarChar(200)
  nilai_rujukan         String @db.VarChar(30)
  keterangan            String @db.VarChar(60)
  bagian_rs             Float
  bhp                   Float
  bagian_perujuk        Float
  bagian_dokter         Float
  bagian_laborat        Float
  kso                   Float?
  menejemen             Float?
  biaya_item            Float

  reg_periksa           reg_periksa @relation(fields: [no_rawat], references: [no_rawat])
  jns_perawatan_lab     jns_perawatan_lab @relation(fields: [kd_jenis_prw], references: [kd_jenis_prw])
  template_laboratorium template_laboratorium @relation(fields: [id_template], references: [id_template])

  @@id([no_rawat, kd_jenis_prw, tgl_periksa, jam, id_template])
}

